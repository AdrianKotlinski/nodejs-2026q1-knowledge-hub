PORT=4000

LOG_LEVEL=log
LOG_MAX_FILE_SIZE=1024

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

#Example:
#local app + docker db: postgresql://user:password@localhost:5432/knowledge_hub?schema=public
#docker app + docker db: postgresql://user:password@db:5432/knowledge_hub?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_hub?schema=public"

# AI Integration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300
